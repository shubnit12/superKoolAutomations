{
  "name": "naukri-automation",
  "version": "0.1.0",
  "private": true,
  "description": "Daily Naukri profile auto-updater — uploads latest resume and refreshes headline so the profile ranks higher in recruiter searches.",
  "main": "dist/index.js",
  "scripts": {
    "login": "ts-node src/login.ts",
    "refresh-auth": "ts-node src/refresh-auth.ts",
    "start": "ts-node src/index.ts",
    "apply": "ts-node src/apply.ts",
    "build": "tsc",
    "start:prod": "node dist/index.js",
    "apply:prod": "node dist/apply.js",
    "refresh-auth:prod": "node dist/refresh-auth.js",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "clean": "rm -rf dist playwright-report test-results"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.16.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
