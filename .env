# Naukri login credentials (used by tests and src/login.ts).
# Real values — this file is gitignored.
NAUKRI_EMAIL=email
NAUKRI_PASSWORD=password

# Resume source — your hosted API endpoint
RESUME_URL=https://api.shubnit.com/resume
# ── Auto-apply chatbot answers ─────────────────────────────────────────
# These feed the keyword-based questionnaire handler in `src/qa-defaults.ts`.
# Used only by `npm run apply` (the auto-apply flow). Edit them to your truth.
# Numeric fields are LPA (lakhs per annum) for compensation, years for experience.

NAUKRI_CURRENT_LOCATION=Gurugram
NAUKRI_PREFERRED_LOCATION_OK=Yes            # answer to "Is your preferred location <X>?" — usually Yes
NAUKRI_CURRENT_ORG=Cognizant
NAUKRI_TOTAL_EXPERIENCE=3.6                 # years
NAUKRI_RELEVANT_EXPERIENCE=3.5              # years
NAUKRI_CURRENT_CTC=6.5                      # LPA
NAUKRI_DESIRED_CTC=9                        # LPA  ← please confirm this value
NAUKRI_NOTICE_PERIOD=30                     # days
NAUKRI_PAN_CARD=IGWPS7062G
NAUKRI_PF_UAN_CLEARED=Yes
